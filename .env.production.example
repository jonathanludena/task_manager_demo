# ── Production Environment ──────────────────────────────────
# Copiá este archivo como .env en el VPS y ajustá los valores.
# docker compose lee automáticamente el .env del directorio raíz.
#
# Uso en el VPS:
#   scp .env.production.example usuario@vps:/ruta/app/.env
#   docker compose up -d --build

# PostgreSQL
DB_PASSWORD=changeme_to_a_secure_password
