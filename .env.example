# ── Production Environment ──────────────────────────────────
# Copiá este archivo como .env en el VPS y ajustá los valores.
# docker compose lee automáticamente el .env del directorio raíz.
#
# Uso en el VPS:
#   scp .env.example usuario@vps:/ruta/app/.env
#   vim .env  # ajustar valores
#   docker compose --profile certbot up -d
#
# Variables disponibles:
#   docker compose config  # muestra la config final con las vars expandidas

# ── PostgreSQL ──────────────────────────────────────────────
DB_PASSWORD=changeme_to_a_secure_password

# ── SSL / Let's Encrypt ────────────────────────────────────
# STAGING=true usa el entorno de staging de Let's Encrypt
# (sin rate limits) para pruebas iniciales. Cambiar a false
# cuando el deploy esté estable y verificado.
STAGING=true

# Email para notificaciones de Let's Encrypt
# (recordatorios de expiración, avisos de revocación, etc.)
CERT_EMAIL=jonathan.ludena@lproconsulting.com

# Dominios cubiertos por el certificado SSL multi-SAN.
# Ambos dominios van en una sola línea, separados por espacio,
# entre comillas dobles.
CERT_DOMAINS="app-challenge-0526.lproconsulting.com api-challenge-0526.lproconsulting.com"
